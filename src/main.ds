// Description:
//   Dust-native executable entrypoint for DustViz.

forge DustVizMain {
    proc K::main() -> UInt32 {
        let status = DustVizCli::K::run_with_host_args();
        let _ = DustVizHost::K::report_status(status);
        return status;
    }
}
